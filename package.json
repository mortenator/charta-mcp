{
  "name": "@charta/mcp",
  "version": "1.0.2",
  "mcpName": "io.github.mortenator/charta",
  "description": "MCP server for generating beautiful, presentation-ready charts (SVG + PNG)",
  "main": "dist/index.js",
  "bin": {
    "charta-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
